# ThinkAloud.ai — Backend Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# Database
DATABASE_URL=postgresql+asyncpg://vishal:vishal16@localhost:5432/thinkaloudai

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET_KEY=change-this-to-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@thinkaloudai.tech

# AI / vLLM (on MI300X)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen3-32B

# LiveKit
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=thinkaloud_key
LIVEKIT_API_SECRET=thinkaloud_secret_change_in_production

# Debug
DEBUG=false
